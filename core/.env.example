# Traceability banner shown in Swagger UI / HTML responses.
ENVIRONMENT=local

# Local development uses the discrete DATABASE_* parts below (the test suite
# also needs them, to create/target a per-run database).
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=
DATABASE_PASSWORD=
DATABASE_NAME=ember
DATABASE_ECHO=false

# Production (docker-compose / Coolify) passes full URLs instead; when set,
# these take precedence over the discrete parts above.
#   DATABASE_URL         runtime (pooled) connection
#   DATABASE_DIRECT_URL  direct (non-pooled) connection, used for migrations
# DATABASE_URL=
# DATABASE_DIRECT_URL=

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=
JWT_ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30
INVITE_CODE_TTL_DAYS=7
