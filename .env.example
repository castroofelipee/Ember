# Deployment environment (docker-compose.yml / Coolify).
# The database is external — provide its connection URLs here.

# Drives the traceability banner (local / development / staging / production).
ENVIRONMENT=production

# Runtime (pooled) connection used by the app.
DATABASE_URL=postgresql://user:password@db-host:5432/ember
# Direct (non-pooled) connection used for migrations. If your provider offers a
# separate direct/session URL (e.g. Supabase), use it here; otherwise repeat
# DATABASE_URL.
DATABASE_DIRECT_URL=postgresql://user:password@db-host:5432/ember

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=

# Optional — sensible defaults applied when omitted.
JWT_ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30
INVITE_CODE_TTL_DAYS=7

# Server-side image uploads for Personal Space. Never expose this to the web container.
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
